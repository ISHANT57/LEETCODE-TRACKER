# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Environment
NODE_ENV=development
PORT=5000

# --- Split frontend/backend deploy ---
# Backend (Render): comma-separated frontend origin(s) allowed by CORS.
# Leave unset for local/monolith development.
FRONTEND_URL=https://leetcode-tracker.vercel.app
# Frontend (Vercel/Cloudflare Pages) build-time var: the backend API origin.
# Must be prefixed with VITE_ to be exposed to the client bundle.
VITE_API_URL=https://leetcode-tracker.onrender.com

# Optional: MongoDB (if using)
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/database

# Optional: Logging
LOG_LEVEL=inf