{
  "permissions": {
    "allow": [
      "Bash(VITE_API_URL=https://example.onrender.com npm run build:client)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(grep -vE \"^\\\\s*#|^\\\\s*$\" .env.example)",
