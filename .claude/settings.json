      "Bash(curl -s -o /dev/null -w \"%{http_code}\\\\n\" http://127.0.0.1:5000/health)",
      "Bash(curl -s -o /dev/null -w \"/api/students -> %{http_code}\\\\n\" http://127.0.0.1:5000/api/students)",
      "Bash(curl -s -o /dev/null -w \"/api/export/csv -> %{http_code}\\\\n\" http://127.0.0.1:5000/api/export/csv)",
      "Bash(npm run *)"
    ]
  }
}
